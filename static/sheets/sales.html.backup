<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sales - Aesthetico Dashboard</title>

    <!-- Bootstrap 5.3 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <!-- DataTables + Bootstrap 5 -->
    <link href="https://cdn.datatables.net/2.1.8/css/dataTables.bootstrap5.min.css" rel="stylesheet">
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/static/css/sheet-common.css">
</head>
<body>

    <!-- Loading Overlay -->
    <div id="loadingOverlay" class="loading-overlay">
        <div class="text-center">
            <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status"></div>
            <p class="mt-3 fw-semibold" id="loadingText">Loading...</p>
        </div>
    </div>

    <!-- Toast Container -->
    <div id="toastContainer" class="toast-container"></div>

    <!-- Sidebar -->
    <aside class="sidebar d-print-none">
        <div class="p-3 border-bottom">
            <h5 class="mb-0 fw-bold text-primary">
                <i class="bi bi-bar-chart-line-fill me-2"></i>Aesthetico
            </h5>
            <small class="text-muted">Order Management</small>
        </div>
        <nav class="flex-grow-1 py-2" id="sheetList">
            <!-- Populated by JavaScript -->
        </nav>
        <div class="sidebar-user">
            <div class="d-flex align-items-center mb-2">
                <div class="user-avatar me-2" id="userAvatar">A</div>
                <div class="flex-grow-1">
                    <div class="fw-semibold small" id="userName">User</div>
                    <span id="userRole" class="badge bg-info">Role</span>
                </div>
            </div>
            <button onclick="auth.logout()" class="btn btn-sm btn-outline-danger w-100">
                <i class="bi bi-box-arrow-right me-1"></i>Logout
            </button>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="main-content">
        <!-- Top Bar -->
        <div class="top-bar">
            <div>
                <h4 class="mb-0" id="sheetTitle">Sales</h4>
                <small class="text-muted" id="sheetInfo">Loading...</small>
            </div>
            <div class="d-flex gap-2">
                <button id="btnRefresh" class="btn btn-sm btn-outline-primary" disabled>
                    <i class="bi bi-arrow-clockwise me-1"></i>Refresh
                </button>
                <button id="btnUpdate" class="btn btn-sm btn-warning" style="display: none;">
                    <i class="bi bi-arrow-repeat me-1"></i>Update Order Statuses
                </button>
            </div>
        </div>

        <!-- Date Range Filter -->
        <div class="card mb-3">
            <div class="card-body">
                <div class="row g-3 align-items-end">
                    <div class="col-md-3">
                        <label for="dateFrom" class="form-label small mb-1">From Date</label>
                        <input type="date" class="form-control form-control-sm" id="dateFrom">
                    </div>
                    <div class="col-md-3">
                        <label for="dateTo" class="form-label small mb-1">To Date</label>
                        <input type="date" class="form-control form-control-sm" id="dateTo">
                    </div>
                    <div class="col-md-3">
                        <button id="btnApplyFilter" class="btn btn-sm btn-primary">
                            <i class="bi bi-funnel me-1"></i>Apply Filter
                        </button>
                        <button id="btnClearFilter" class="btn btn-sm btn-outline-secondary">
                            <i class="bi bi-x-circle me-1"></i>Clear
                        </button>
                    </div>
                    <div class="col-md-3 text-end">
                        <small class="text-muted" id="filterInfo">No filter applied</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Table Container -->
        <div class="table-container">
            <!-- Empty State -->
            <div id="emptyState" class="empty-state">
                <i class="bi bi-table"></i>
                <h5>No Data</h5>
                <p>Select a sheet from the sidebar to view data.</p>
            </div>

            <!-- Table Wrapper -->
            <div id="tableWrapper" class="d-none">
                <table id="dataTable" class="table table-striped table-hover table-sm">
                    <thead><tr></tr></thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </main>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/2.1.8/js/dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/2.1.8/js/dataTables.bootstrap5.min.js"></script>
    
    <!-- Core Modules -->
    <script src="/static/js/auth.js" onerror="console.error('[HTML] FAILED to load auth.js')"></script>
    <script src="/static/js/ui.js" onerror="console.error('[HTML] FAILED to load ui.js')"></script>
    <script src="/static/js/api.js" onerror="console.error('[HTML] FAILED to load api.js')"></script>
    <script src="/static/js/common.js" onerror="console.error('[HTML] FAILED to load common.js')"></script>
    
    <!-- Sheet-Specific Script -->
    <script src="/static/js/sheets/sales.js" onerror="console.error('[HTML] FAILED to load sales.js')"></script>
    
    <script>
        console.log("[HTML] All script tags added to page");
        window.onerror = function(message, source, lineno, colno, error) {
            console.error("[HTML] Global JavaScript Error:", {
                message: message,
                source: source,
                line: lineno,
                column: colno,
                error: error
            });
            return false;
        };
    </script>
    
    <!-- Debug Script -->
    <script>
        console.log("[HTML] Page loaded, checking elements...");
        
        // Test if sales.js is loaded
        setTimeout(function() {
            console.log("[HTML] Checking if sales.js executed...");
            console.log("[HTML] Looking for any errors in console above...");
        }, 500);
        
        window.addEventListener('load', function() {
            console.log("[HTML] Window load event fired");
            setTimeout(function() {
                const dateFrom = document.getElementById("dateFrom");
                const dateTo = document.getElementById("dateTo");
                const btnApplyFilter = document.getElementById("btnApplyFilter");
                const btnClearFilter = document.getElementById("btnClearFilter");
                
                console.log("[HTML] Filter elements check:", {
                    dateFrom: dateFrom ? "EXISTS" : "NOT FOUND",
                    dateTo: dateTo ? "EXISTS" : "NOT FOUND", 
                    btnApplyFilter: btnApplyFilter ? "EXISTS" : "NOT FOUND",
                    btnClearFilter: btnClearFilter ? "EXISTS" : "NOT FOUND"
                });
                
                if (btnApplyFilter) {
                    console.log("[HTML] Setting up MANUAL test listener on Apply Filter");
                    
                    // Check if modules are loaded
                    console.log("[HTML] Checking modules:", {
                        auth: typeof auth !== 'undefined',
                        api: typeof api !== 'undefined',
                        ui: typeof ui !== 'undefined'
                    });
                    
                    btnApplyFilter.addEventListener("click", function() {
                        console.log("[HTML] MANUAL listener fired!");
                        
                        const df = document.getElementById("dateFrom").value;
                        const dt = document.getElementById("dateTo").value;
                        console.log(`[HTML] Date values: from='${df}', to='${dt}'`);
                        
                        if (df || dt) {
                            console.log("[HTML] Calling API manually...");
                            let url = `/api/sheets/Sales`;
                            const params = new URLSearchParams();
                            if (df) params.append('date_from', df);
                            if (dt) params.append('date_to', dt);
                            if (params.toString()) url += '?' + params.toString();
                            
                            console.log("[HTML] Full URL:", url);
                            
                            // Get token from correct localStorage key
                            const token = localStorage.getItem('auth_token');
                            console.log("[HTML] Token found:", token ? "YES" : "NO");
                            
                            fetch(url, {
                                headers: {
                                    'Authorization': 'Bearer ' + token
                                }
                            })
                            .then(response => {
                                console.log("[HTML] Response status:", response.status);
                                if (!response.ok) {
                                    throw new Error(`HTTP ${response.status}`);
                                }
                                return response.json();
                            })
                            .then(data => {
                                console.log("[HTML] API Response:", data);
                                console.log(`[HTML] Received ${data.rows ? data.rows.length : 'unknown'} rows`);
                                alert(`Success! Received ${data.rows ? data.rows.length : 'unknown'} rows with date filter applied. Please refresh the page to see the filtered data.`);
                            })
                            .catch(err => {
                                console.error("[HTML] API Error:", err);
                                alert("Error: " + err.message);
                            });
                        } else {
                            alert("Please select at least one date");
                        }
                    });
                }
            }, 1000);
        });
    </script>
</body>
</html>
